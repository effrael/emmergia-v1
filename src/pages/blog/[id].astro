---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/ui/Hero.astro";
import Footer from "../../components/ui/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("es-PE", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<Layout>
  <!-- Dark hero section -->
  <div style="background: var(--gradient-bg); color: var(--white)">
    <Hero />
    <section class="max-w-[860px] mx-auto px-8 py-32">
      <!-- Category badge -->
      <span
        class="inline-block text-[0.68rem] font-bold tracking-[0.18em] uppercase px-2.5 py-1 rounded-full mb-6"
        style="background: rgba(240,0,127,0.15); color: var(--pink); border: 1px solid rgba(240,0,127,0.25);"
      >
        {post.data.category}
      </span>

      <!-- Title -->
      <h1
        class="font-obli text-4xl md:text-5xl font-bold leading-tight text-white mt-4 mb-6 text-balance"
        data-animate="fade-up"
      >
        {post.data.title}
      </h1>

      <!-- Description -->
      <p
        class="text-[1rem] text-white/65 leading-relaxed max-w-[640px] mb-8"
        data-animate="fade-up"
        data-animate-delay="80"
      >
        {post.data.description}
      </p>

      <!-- Metadata -->
      <div
        class="flex items-center gap-5 text-[0.82rem] text-white/45"
        data-animate="fade-up"
        data-animate-delay="140"
      >
        <span class="flex items-center gap-1.5">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          {formatDate(post.data.date)}
        </span>
        <span class="flex items-center gap-1.5">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
          {post.data.readTime} de lectura
        </span>
      </div>
    </section>
  </div>

  <!-- Article content -->
  <section class="bg-white">
    <div class="max-w-[780px] mx-auto px-8 py-16">
      <div class="blog-prose">
        <Content />
      </div>

      <!-- CTA section -->
      <div class="mt-16">
        <div
          class="relative rounded-2xl overflow-hidden px-8 py-14 flex flex-col items-center text-center gap-5"
          style="background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(240,0,127,0.35), transparent 70%), radial-gradient(ellipse 50% 60% at 80% 100%, rgba(180,40,0,0.5), transparent 65%), #100a0f;"
        >
          <h2
            class="font-obli text-[clamp(1.6rem,3.5vw,2.4rem)] font-bold leading-tight text-white m-0"
          >
            ¿Tienes dudas sobre tu régimen?
            <em
              class="not-italic bg-clip-text text-transparent bg-gradient-to-r from-pink to-orange"
            >
              Hablemos.
            </em>
          </h2>
          <p class="text-[0.88rem] text-white/55 leading-relaxed max-w-[380px] m-0">
            Agenda una reunión de diagnóstico de 30 min sin costo. Te diremos
            exactamente cuánto puedes ahorrar optimizando tu régimen tributario.
          </p>
          <a
            href="https://wa.me/51999999999"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-white text-sm font-semibold hover:opacity-90 transition-opacity no-underline"
            style="background: var(--gradient-btn)"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              />
            </svg>
            Escríbenos por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* ── Blog prose styles ── */

  .blog-prose h2 {
    font-family: var(--font-obli, "Fraunces Variable", serif);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.25;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(90deg, var(--pink), var(--orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-prose h3 {
    font-family: var(--font-obli, "Fraunces Variable", serif);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--black);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-prose p {
    color: #444;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .blog-prose blockquote {
    border-left: 3px solid var(--pink);
    background: rgba(240, 0, 127, 0.04);
    padding: 1rem 1.5rem;
    border-radius: 0 0.75rem 0.75rem 0;
    font-style: italic;
    color: #555;
    margin: 1.5rem 0;
  }

  .blog-prose blockquote p {
    margin-bottom: 0;
  }

  .blog-prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 2rem;
  }

  .blog-prose th {
    background: linear-gradient(90deg, var(--pink), var(--orange));
    color: #fff;
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .blog-prose td {
    border-bottom: 1px solid #eee;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #444;
  }

  .blog-prose tr:nth-child(even) td {
    background: #fafafa;
  }

  .blog-prose ul,
  .blog-prose ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: #444;
    line-height: 1.75;
  }

  .blog-prose ul li,
  .blog-prose ol li {
    margin-bottom: 0.4rem;
  }

  .blog-prose strong {
    color: var(--black);
    font-weight: 700;
  }

  .blog-prose a {
    color: var(--pink);
    text-decoration: underline;
  }

  .blog-prose hr {
    border: none;
    border-top: 1px solid #eee;
    margin: 2.5rem 0;
  }
</style>
