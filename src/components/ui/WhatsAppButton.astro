---
import LifeBuoy from "@lucide/astro/icons/life-buoy";
---

<!-- Contact Fixed Button -->
<div class="whatsapp-wrapper">
  <span class="whatsapp-label">👋 ¡Hola! ¿Necesitas ayuda?</span>
  <a
    href="https://api.whatsapp.com/send?phone=51961807577"
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-fab"
    aria-label="Escríbenos por WhatsApp"
  >
    <LifeBuoy size={26} color="white" stroke-width={1.5} />
  </a>
</div>

<style>
  .whatsapp-wrapper {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .whatsapp-wrapper.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .whatsapp-fab {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: #000;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
    text-decoration: none;
    transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .whatsapp-fab:hover {
    background: #111;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.5);
    transform: scale(1.07);
  }

  .whatsapp-label {
    background: #fff;
    color: #111;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    padding: 7px 14px;
    border-radius: 999px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    opacity: 0;
    transform: translateX(6px);
    transition: opacity 0.35s ease 2s, transform 0.35s ease 2s;
    pointer-events: none;
  }

  .whatsapp-wrapper.is-visible .whatsapp-label {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  function initWhatsApp() {
    const wrapper = document.querySelector(".whatsapp-wrapper") as HTMLElement;
    if (!wrapper) return;

    function onScroll() {
      wrapper.classList.toggle("is-visible", window.scrollY > 200);
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener("astro:page-load", initWhatsApp);
</script>
