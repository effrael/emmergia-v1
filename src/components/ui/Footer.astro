---
const servicios = [
  { label: "Contabilidad", href: "#" },
  { label: "Legal", href: "#" },
  { label: "Automatización", href: "#" },
];

const recursos = [
  { label: "Blog", href: "#" },
  { label: "Calculadora tributaria", href: "#" },
];

const contacto = [
  { label: "WhatsApp", href: "https://wa.me/51999999999" },
  { label: "hola@emmergia.pe", href: "mailto:hola@emmergia.biz" },
  { label: "Lima, Perú", href: "#" },
];

const legal = [
  { label: "Términos", href: "#" },
  { label: "Privacidad", href: "#" },
  { label: "Cookies", href: "#" },
];
---

<footer class="border-t border-[#eee]">
  <!-- Main row -->
  <div
    class="max-w-[1280px] mx-auto px-8 py-14 grid md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-12"
  >
    <!-- Brand -->
    <div class="flex flex-col gap-4">
      <a href="/" class="flex items-center gap-2 no-underline w-fit">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <polygon points="0,0 22,11 0,22" fill="url(#footer-grad)"></polygon>
          <defs>
            <linearGradient id="footer-grad" x1="0" y1="0" x2="22" y2="22">
              <stop offset="0%" stop-color="var(--pink)"></stop>
              <stop offset="100%" stop-color="var(--orange)"></stop>
            </linearGradient>
          </defs>
        </svg>
        <span class="text-base font-bold tracking-[0.08em] text-[var(--black)]"
          >EMMERGIA</span
        >
      </a>
      <p class="text-[0.85rem] text-[#666] leading-relaxed m-0 max-w-[220px]">
        Estudio contable de próxima generación. Contabilidad, legal y
        automatización — integrados como un solo servicio.
      </p>
    </div>

    <!-- Servicios -->
    <div class="flex flex-col gap-4">
      <span
        class="text-[0.7rem] font-bold tracking-[0.15em] text-[#999] uppercase"
        >Servicios</span
      >
      <ul class="flex flex-col gap-3 list-none m-0 p-0">
        {
          servicios.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-[0.875rem] text-[#444] hover:text-[var(--pink)] transition-colors no-underline"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Recursos -->
    <div class="flex flex-col gap-4">
      <span
        class="text-[0.7rem] font-bold tracking-[0.15em] text-[#999] uppercase"
        >Recursos</span
      >
      <ul class="flex flex-col gap-3 list-none m-0 p-0">
        {
          recursos.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-[0.875rem] text-[#444] hover:text-[var(--pink)] transition-colors no-underline"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Contacto -->
    <div class="flex flex-col gap-4">
      <span
        class="text-[0.7rem] font-bold tracking-[0.15em] text-[#999] uppercase"
        >Contacto</span
      >
      <ul class="flex flex-col gap-3 list-none m-0 p-0">
        {
          contacto.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-[0.875rem] text-[#444] hover:text-[var(--pink)] transition-colors no-underline"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[#eee]">
    <div
      class="max-w-[1280px] mx-auto px-8 py-5 flex items-center justify-center"
    >
      <span class="text-[0.78rem] text-[#aaa]">
        © 2026 <a href="/"><strong>EMMERGIA</strong></a> · Todos los derechos reservados.
      </span>
    </div>
  </div>
</footer>

<!-- WhatsApp Fixed Button -->
<a
  href="https://wa.me/51999999999"
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-fab"
  aria-label="Escríbenos por WhatsApp"
>
  <!-- Ícono WhatsApp -->
  <svg
    class="whatsapp-icon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    width="26"
    height="26"
    fill="white"
  >
    <path d="M16 .004C7.164.004 0 7.168 0 16.004c0 2.824.738 5.478 2.027 7.788L.056 31.996l8.394-2.198A15.93 15.93 0 0016 32.004c8.836 0 16-7.164 16-16S24.836.004 16 .004zm0 29.12a13.1 13.1 0 01-6.68-1.826l-.478-.285-4.985 1.306 1.329-4.858-.312-.5A13.07 13.07 0 012.88 16.004C2.88 8.748 8.744 2.884 16 2.884c7.256 0 13.12 5.864 13.12 13.12S23.256 29.124 16 29.124zm7.19-9.822c-.394-.197-2.332-1.15-2.693-1.281-.362-.132-.625-.197-.888.197-.263.394-1.019 1.281-1.25 1.544-.23.263-.46.296-.854.099-.394-.197-1.664-.614-3.169-1.956-1.171-1.045-1.961-2.335-2.191-2.729-.23-.394-.025-.607.173-.803.177-.176.394-.46.591-.69.197-.23.263-.394.394-.657.132-.263.066-.493-.033-.69-.099-.197-.888-2.139-1.217-2.928-.32-.77-.645-.666-.888-.678l-.757-.013c-.263 0-.69.099-1.052.493-.362.394-1.382 1.35-1.382 3.292s1.415 3.817 1.612 4.08c.197.263 2.783 4.25 6.743 5.96.943.407 1.678.65 2.251.832.946.301 1.806.259 2.487.157.759-.113 2.332-.953 2.661-1.874.329-.92.329-1.71.23-1.874-.098-.164-.361-.263-.756-.46z"/>
  </svg>
  <span class="whatsapp-label">Escríbenos</span>
</a>

<style>
  .whatsapp-fab {
    position: fixed;
    bottom: 28px;
    left: 28px;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0;
    background: #25D366;
    border-radius: 999px;
    padding: 13px;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
    text-decoration: none;
    overflow: hidden;
    max-width: 52px;
    transition:
      max-width 0.35s cubic-bezier(.4,0,.2,1),
      padding 0.35s cubic-bezier(.4,0,.2,1),
      box-shadow 0.2s ease;
  }

  .whatsapp-fab:hover {
    max-width: 200px;
    padding: 13px 20px 13px 16px;
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.6);
    background: #20ba5a;
  }

  .whatsapp-icon {
    flex-shrink: 0;
  }

  .whatsapp-label {
    color: #fff;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
    opacity: 0;
    max-width: 0;
    margin-left: 0;
    transition:
      opacity 0.2s ease 0.05s,
      max-width 0.35s cubic-bezier(.4,0,.2,1),
      margin-left 0.35s cubic-bezier(.4,0,.2,1);
  }

  .whatsapp-fab:hover .whatsapp-label {
    opacity: 1;
    max-width: 140px;
    margin-left: 10px;
  }
</style>
