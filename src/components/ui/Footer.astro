---
import Image from "astro/components/Image.astro";
import Animation from "./Animation.astro";
import WhatsAppButton from "./WhatsAppButton.astro";

const servicios = [
  { label: "Contabilidad", href: "/contabilidad" },
  { label: "Legal", href: "/legal" },
  { label: "Automatización", href: "/automatizacion" },
];

const recursos = [
  { label: "Blog", href: "/blog" },
];

const contacto = [
  { label: "WhatsApp", href: "https://wa.me/51999999999" },
  { label: "crece@emmergia.biz", href: "mailto:crece@emmergia.biz" },
  { label: "Lima, Perú", href: "#" },
];

---

<footer class="border-t border-[#eee]">
  <!-- Main row -->
  <div
    class="max-w-[1280px] mx-auto px-8 py-14 grid md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-12"
  >
    <!-- Brand -->
    <div class="flex flex-col gap-4">
      <a href="/" class="flex items-center gap-2 no-underline w-fit">
             <Image src="/logo_emmergia.webp" alt="Logo EMMERGIA" width="650" height="149" class="w-[140px] md:w-full h-auto md:h-10 filter brightness-0"/>

      </a>
      <p class="text-[0.85rem] text-[#666] leading-relaxed m-0 max-w-[220px]">
      Somos una Consultora de próxima generación. Contabilidad, legal y automatización — integrados como un solo servicio.
      </p>
    </div>

    <!-- Servicios -->
    <div class="flex flex-col gap-4">
      <span
        class="text-[0.7rem] font-black text-[#999] uppercase"
        >Servicios</span
      >
      <ul class="flex flex-col gap-3 list-none m-0 p-0">
        {
          servicios.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-[0.875rem] text-[#444] hover:text-[var(--pink)] transition-colors no-underline"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Recursos -->
    <div class="flex flex-col gap-4">
      <span
        class="text-[0.7rem] font-black text-[#999] uppercase"
        >Recursos</span
      >
      <ul class="flex flex-col gap-3 list-none m-0 p-0">
        {
          recursos.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-[0.875rem] text-[#444] hover:text-[var(--pink)] transition-colors no-underline"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Contacto -->
    <div class="flex flex-col gap-4">
      <span
        class="text-[0.7rem] font-black text-[#999] uppercase"
        >Contacto</span
      >
      <ul class="flex flex-col gap-3 list-none m-0 p-0">
        {
          contacto.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-[0.875rem] text-[#444] hover:text-[var(--pink)] transition-colors no-underline"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[#eee]">
    <div
      class="max-w-[1280px] mx-auto px-8 py-5 flex items-center justify-center"
    >
      <span class="text-[0.78rem] text-[#aaa]">
        © 2026 <a href="/"><strong>EMMERGIA</strong></a> · Todos los derechos reservados.
      </span>
    </div>
  </div>
</footer>

<WhatsAppButton />