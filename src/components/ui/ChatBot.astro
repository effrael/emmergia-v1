<div class="w-full max-w-4xl h-[620px] bg-[#0a0a0f]/40 backdrop-blur-2xl border border-white/10 rounded-2xl flex flex-col overflow-hidden shadow-2xl text-white font-sans">
    
    <header class="px-6 py-4 bg-white/[0.02] backdrop-blur-md border-b border-white/10 flex items-center justify-between">
