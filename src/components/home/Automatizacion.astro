---

---

<section
  class="auto-section max-w-[1280px] mx-auto px-8 py-16 grid md:grid-cols-2 items-center gap-10 md:gap-20"
>
  <!-- Left -->
  <div class="auto-text flex flex-col gap-6">
    <div class="flex items-center gap-3">
      <span class="w-8 h-[2px] bg-pink"></span>
      <span
        class="text-[0.75rem] font-bold tracking-[0.15em] text-pink uppercase"
        >Automatización</span
      >
    </div>

    <h2
      class="font-obli text-[clamp(2.2rem,4vw,3.2rem)] font-bold leading-[1.05] text-[var(--black)] m-0"
    >
      Moderniza tu <br />
      "Back Office":
      <em
        class="italic bg-clip-text text-transparent bg-gradient-to-r from-pink to-orange"
        >de la digitación manual a la Inteligencia Artificial.</em
      >
    </h2>

    <p class="text-[0.95rem] text-[#444] leading-relaxed max-w-[480px] m-0">
      ¿Tu equipo contable sigue perdiendo horas picando datos, conciliando
      bancos en Excel y corrigiendo errores de tipeo?
      <strong class="text-[var(--black)]">Eso es cosa del pasado.</strong>
      Implementamos ecosistemas de automatización que conectan tus ventas, compras
      y bancos en tiempo real. Reducimos la carga operativa manual entre un 50% a
      75%., transformando a tu equipo contable: de digitadores estresados a analistas
      financieros que aportan valor real a tu estrategia.
    </p>
    <div
      class="inline-flex w-fit px-4 py-2.5 italic rounded-full text-[0.8rem] font-bold"
      style=" color: var(--orange)"
    >
      ~ Menos horas hombre en tareas repetitivas, más rentabilidad por empleado.
    </div>

    <div>
      <a
        href="https://wa.link/m7nowd"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-white text-sm font-black hover:opacity-90 transition-opacity no-underline"
        style="background: var(--gradient-btn)"
      >
        Automatizar mis procesos →
      </a>
    </div>
  </div>

  <!-- Right: n8n-style workflow -->
  <div class="auto-img">
    <svg
      viewBox="0 0 700 420"
      class="w-full h-auto"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      font-family="system-ui, -apple-system, sans-serif"
      text-rendering="geometricPrecision"
    >
      <defs>
        <linearGradient id="eg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#f0007f"/>
          <stop offset="100%" stop-color="#f77c1e"/>
        </linearGradient>
        <filter id="sh" x="-8%" y="-8%" width="120%" height="135%">
          <feDropShadow dx="0" dy="2" stdDeviation="4" flood-opacity="0.07"/>
        </filter>
        <filter id="gl" x="-100%" y="-100%" width="300%" height="300%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="2.5" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <pattern id="grid" width="18" height="18" patternUnits="userSpaceOnUse">
          <circle cx="9" cy="9" r="0.7" fill="#d4d4d8"/>
        </pattern>
      </defs>

      <!-- Canvas -->
      <rect width="700" height="420" rx="16" fill="#fafafa"/>
      <rect width="700" height="420" rx="16" fill="url(#grid)"/>
      <rect x="0.5" y="0.5" width="699" height="419" rx="16" fill="none" stroke="#e5e7eb" stroke-width="1"/>

      <!-- ── Connection paths ── -->
      <!-- Inputs → Engine -->
      <path id="pi1" d="M146,51 C215,51 210,216 275,216" stroke="#d4d4d8" stroke-width="1.5"/>
      <path id="pi2" d="M130,151 C200,151 205,216 275,216" stroke="#d4d4d8" stroke-width="1.5"/>
      <path id="pi3" d="M156,255 C220,255 215,216 275,216" stroke="#d4d4d8" stroke-width="1.5"/>
      <path id="pi4" d="M136,347 C205,347 210,216 275,216" stroke="#d4d4d8" stroke-width="1.5"/>
      <!-- Engine → Outputs -->
      <path id="po1" d="M425,216 C495,216 492,57 556,57" stroke="#d4d4d8" stroke-width="1.5"/>
      <path id="po2" d="M425,216 C493,216 490,161 542,161" stroke="#d4d4d8" stroke-width="1.5"/>
      <path id="po3" d="M425,216 C495,216 498,267 560,267" stroke="#d4d4d8" stroke-width="1.5"/>
      <path id="po4" d="M425,216 C497,216 494,361 546,361" stroke="#d4d4d8" stroke-width="1.5"/>

      <!-- ── Animated dots (data flowing) ── -->
      <g filter="url(#gl)">
        <!-- pi1 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="0s"><mpath href="#pi1"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="0s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.3s"><mpath href="#pi1"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="1.3s"/>
        </circle>
        <!-- pi2 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="0.4s"><mpath href="#pi2"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="0.4s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.7s"><mpath href="#pi2"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="1.7s"/>
        </circle>
        <!-- pi3 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="0.8s"><mpath href="#pi3"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="0.8s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="2.1s"><mpath href="#pi3"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="2.1s"/>
        </circle>
        <!-- pi4 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.2s"><mpath href="#pi4"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="1.2s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="2.5s"><mpath href="#pi4"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="2.5s"/>
        </circle>
        <!-- po1 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="0.2s"><mpath href="#po1"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="0.2s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.5s"><mpath href="#po1"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="1.5s"/>
        </circle>
        <!-- po2 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="0.6s"><mpath href="#po2"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="0.6s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.9s"><mpath href="#po2"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="1.9s"/>
        </circle>
        <!-- po3 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.0s"><mpath href="#po3"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="1.0s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="2.3s"><mpath href="#po3"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="2.3s"/>
        </circle>
        <!-- po4 -->
        <circle r="3.5" fill="#f0007f">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="1.4s"><mpath href="#po4"/></animateMotion>
          <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="1.4s"/>
        </circle>
        <circle r="2" fill="#f77c1e">
          <animateMotion dur="2.5s" repeatCount="indefinite" begin="2.7s"><mpath href="#po4"/></animateMotion>
          <animate attributeName="opacity" values="0;.7;.7;0" keyTimes="0;0.1;0.9;1" dur="2.5s" repeatCount="indefinite" begin="2.7s"/>
        </circle>
      </g>

      <!-- ── Connector ports (n8n style) ── -->
      <circle cx="146" cy="51" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>
      <circle cx="130" cy="151" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>
      <circle cx="156" cy="255" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>
      <circle cx="136" cy="347" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>
      <circle cx="275" cy="216" r="5" fill="white" stroke="#f0007f" stroke-width="1.5"/>
      <circle cx="425" cy="216" r="5" fill="white" stroke="#f77c1e" stroke-width="1.5"/>
      <circle cx="556" cy="57" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>
      <circle cx="542" cy="161" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>
      <circle cx="560" cy="267" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>
      <circle cx="546" cy="361" r="4" fill="white" stroke="#d4d4d8" stroke-width="1.2"/>

      <!-- ── Column labels ── -->
      <text x="82" y="18" text-anchor="middle" font-size="8" font-weight="700" letter-spacing="1.5" fill="#6366f1" opacity="0.5">ENTRADAS</text>
      <text x="618" y="24" text-anchor="middle" font-size="8" font-weight="700" letter-spacing="1.5" fill="#16a34a" opacity="0.5">SALIDAS</text>

      <!-- ── INPUT NODES ── -->
      <g filter="url(#sh)">
        <!-- Facturas CPE -->
        <g>
          <rect x="18" y="27" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="34" cy="51" r="6" fill="#eef2ff" stroke="#c7d2fe" stroke-width="0.5"/>
          <circle cx="34" cy="51" r="2.5" fill="#6366f1"/>
          <text x="46" y="47" font-size="9" font-weight="700" fill="#1a1a2e">Facturas CPE</text>
          <text x="46" y="59" font-size="6.5" fill="#94a3b8">1,248 docs/mes</text>
        </g>
        <!-- Bancos -->
        <g>
          <rect x="2" y="127" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="18" cy="151" r="6" fill="#eef2ff" stroke="#c7d2fe" stroke-width="0.5"/>
          <circle cx="18" cy="151" r="2.5" fill="#6366f1"/>
          <text x="30" y="147" font-size="9" font-weight="700" fill="#1a1a2e">Bancos</text>
          <text x="30" y="159" font-size="6.5" fill="#94a3b8">BCP · BBVA · IBK</text>
        </g>
        <!-- POS / e-commerce -->
        <g>
          <rect x="28" y="231" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="44" cy="255" r="6" fill="#eef2ff" stroke="#c7d2fe" stroke-width="0.5"/>
          <circle cx="44" cy="255" r="2.5" fill="#6366f1"/>
          <text x="56" y="251" font-size="9" font-weight="700" fill="#1a1a2e">POS / e-commerce</text>
          <text x="56" y="263" font-size="6.5" fill="#94a3b8">Niubiz · Culqi</text>
        </g>
        <!-- Planilla -->
        <g>
          <rect x="8" y="323" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="24" cy="347" r="6" fill="#eef2ff" stroke="#c7d2fe" stroke-width="0.5"/>
          <circle cx="24" cy="347" r="2.5" fill="#6366f1"/>
          <text x="36" y="343" font-size="9" font-weight="700" fill="#1a1a2e">Planilla</text>
          <text x="36" y="355" font-size="6.5" fill="#94a3b8">T-Registro · PLAME</text>
        </g>
      </g>

      <!-- ── CENTER ENGINE ── -->
      <!-- Pulsing glow -->
      <rect x="267" y="155" width="166" height="122" rx="20" fill="url(#eg)" opacity="0.12">
        <animate attributeName="opacity" values="0.06;0.22;0.06" dur="3s" repeatCount="indefinite"/>
      </rect>
      <!-- Marching ants -->
      <rect x="270" y="158" width="160" height="116" rx="18" fill="none" stroke-dasharray="4 3" stroke="#f0007f" stroke-opacity="0.25" stroke-width="1">
        <animate attributeName="stroke-dashoffset" from="0" to="-70" dur="8s" repeatCount="indefinite"/>
      </rect>
      <!-- Body -->
      <g filter="url(#sh)">
        <rect x="275" y="163" width="150" height="106" rx="14" fill="url(#eg)"/>
      </g>
      <!-- Logo -->
      <image href="/logo_emmergia.webp" x="310" y="172" width="80" height="18" style="filter: brightness(0) invert(1); opacity: 0.9;"/>
      <!-- Labels -->
      <text x="350" y="205" text-anchor="middle" font-size="7.5" font-weight="800" letter-spacing="1.5" fill="white" opacity="0.75">MOTOR IA</text>
      <text x="350" y="219" text-anchor="middle" font-size="6.5" fill="white" opacity="0.65">Clasificación</text>
      <text x="350" y="231" text-anchor="middle" font-size="6.5" fill="white" opacity="0.65">Conciliación</text>
      <text x="350" y="243" text-anchor="middle" font-size="6.5" fill="white" opacity="0.65">Libros contables</text>
      <!-- 24/7 badge -->
      <rect x="328" y="250" width="44" height="15" rx="7.5" fill="white" fill-opacity="0.92"/>
      <text x="350" y="261" text-anchor="middle" font-size="7.5" font-weight="800" fill="#f0007f">24/7</text>

      <!-- ── OUTPUT NODES ── -->
      <g filter="url(#sh)">
        <!-- Reportes -->
        <g>
          <rect x="556" y="33" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="572" cy="57" r="6" fill="#f0fdf4" stroke="#bbf7d0" stroke-width="0.5"/>
          <circle cx="572" cy="57" r="2.5" fill="#16a34a"/>
          <text x="584" y="53" font-size="9" font-weight="700" fill="#1a1a2e">Reportes</text>
          <text x="584" y="65" font-size="6.5" fill="#94a3b8">Diario · semanal</text>
        </g>
        <!-- PLE / SUNAT -->
        <g>
          <rect x="542" y="137" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="558" cy="161" r="6" fill="#f0fdf4" stroke="#bbf7d0" stroke-width="0.5"/>
          <circle cx="558" cy="161" r="2.5" fill="#16a34a"/>
          <text x="570" y="157" font-size="9" font-weight="700" fill="#1a1a2e">PLE / SUNAT</text>
          <text x="570" y="169" font-size="6.5" fill="#94a3b8">Libros electrónicos</text>
        </g>
        <!-- Tablero en vivo -->
        <g>
          <rect x="560" y="243" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="576" cy="267" r="6" fill="#f0fdf4" stroke="#bbf7d0" stroke-width="0.5"/>
          <circle cx="576" cy="267" r="2.5" fill="#16a34a"/>
          <text x="588" y="263" font-size="9" font-weight="700" fill="#1a1a2e">Tablero en vivo</text>
          <text x="588" y="275" font-size="6.5" fill="#94a3b8">KPIs financieros</text>
        </g>
        <!-- Alertas -->
        <g>
          <rect x="546" y="337" width="128" height="48" rx="8" fill="white" stroke="#e2e8f0" stroke-width="0.7"/>
          <circle cx="562" cy="361" r="6" fill="#f0fdf4" stroke="#bbf7d0" stroke-width="0.5"/>
          <circle cx="562" cy="361" r="2.5" fill="#16a34a"/>
          <text x="574" y="357" font-size="9" font-weight="700" fill="#1a1a2e">Alertas</text>
          <text x="574" y="369" font-size="6.5" fill="#94a3b8">Vencimientos · flujo</text>
        </g>
      </g>
    </svg>
  </div>
</section>

<style>
  .auto-section {
    overflow: clip;
  }

  .auto-text {
    opacity: 0;
    transition: opacity 2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .auto-img {
    opacity: 0;
    transform: translateX(160px);
    transition:
      opacity 2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (max-width: 768px) {
    .auto-img { transform: translateX(60px); }
  }

  .auto-text.in-view { opacity: 1; }
  .auto-img.in-view  { opacity: 1; transform: translateX(0); }
</style>

<script>
  const section = document.querySelector(".auto-section") as HTMLElement;
  const text    = document.querySelector(".auto-text") as HTMLElement;
  const img     = document.querySelector(".auto-img") as HTMLElement;

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        text.classList.add("in-view");
        img.classList.add("in-view");
      } else {
        text.classList.remove("in-view");
        img.classList.remove("in-view");
      }
    },
    { threshold: window.innerWidth < 768 ? 0.15 : 0.75 },
  );

  observer.observe(section);
</script>
