---
const features = [
  {
    badge: "70%",
    text: "Menos carga operativa manual. <strong>Tu equipo deja de digitar</strong> y empieza a analizar.",
  },
  {
    badge: "24/7",
    text: "Conciliación bancaria automática con BCP, BBVA, Interbank y Scotiabank.",
  },
  {
    badge: "IA",
    text: "Clasificación inteligente de comprobantes electrónicos directo del CPE SUNAT.",
  },
];

const grid = [
  // row 1
  {
    type: "ENTRADA",
    title: "Facturación electrónica",
    sub: "CPE · 1,248 docs/mes",
    highlight: false,
  },
  {
    type: "ENTRADA",
    title: "Bancos",
    sub: "BCP · BBVA · IBK",
    highlight: false,
  },
  {
    type: "ENTRADA",
    title: "POS y e-commerce",
    sub: "Niubiz · Culqi · Shopify",
    highlight: false,
  },
  // row 2
  {
    type: "ENTRADA",
    title: "Planilla",
    sub: "T-Registro · PLAME",
    highlight: false,
  },
  {
    type: "MOTOR EMMERGIA",
    title: "Clasificación +\nconciliación +\nlibros",
    sub: "IA + reglas contables peruanas",
    highlight: true,
  },
  {
    type: "SALIDA",
    title: "Reportes al socio",
    sub: "Diario · semanal",
    highlight: false,
  },
  // row 3
  {
    type: "SALIDA",
    title: "PLE / SUNAT",
    sub: "Libros electrónicos",
    highlight: false,
  },
  {
    type: "SALIDA",
    title: "Tablero en vivo",
    sub: "KPIs financieros",
    highlight: false,
  },
  {
    type: "SALIDA",
    title: "Alertas",
    sub: "Vencimientos · flujo",
    highlight: false,
  },
];
---

<section
  class="auto-section max-w-[1280px] mx-auto px-8 py-16 grid md:grid-cols-2 items-center gap-10 md:gap-20"
>
  <!-- Left -->
  <div class="auto-text flex flex-col gap-6">
    <!-- Eyebrow -->
    <div class="flex items-center gap-3">
      <span class="w-8 h-[2px] bg-pink"></span>
      <span
        class="text-[0.75rem] font-bold tracking-[0.15em] text-pink uppercase"
        >Automatización</span
      >
    </div>

    <!-- Headline -->
    <h2
      class="font-obli text-[clamp(2.2rem,4vw,3.2rem)] font-bold leading-[1.05] text-[var(--black)] m-0"
    >
      Moderniza tu <br />
      "Back Office":
      <em
        class="italic bg-clip-text text-transparent bg-gradient-to-r from-pink to-orange"
        >de la digitación manual a la Inteligencia Artificial.</em
      >
    </h2>

    <!-- Body -->
    <p class="text-[0.95rem] text-[#444] leading-relaxed max-w-[480px] m-0">
      ¿Tu equipo contable sigue perdiendo horas picando datos, conciliando
      bancos en Excel y corrigiendo errores de tipeo?
      <strong class="text-[var(--black)]">Eso es cosa del pasado.</strong>
      Implementamos ecosistemas de automatización que conectan tus ventas, compras
      y bancos en tiempo real. Reducimos la carga operativa manual en un 70%, transformando
      a tu equipo contable: de digitadores estresados a analistas financieros que
      aportan valor real a tu estrategia.
    </p>
    <div
      class="inline-flex w-fit px-4 py-2.5 italic rounded-full text-[0.8rem] font-bold"
      style=" color: var(--orange)"
    >
      ~ Menos horas hombre en tareas repetitivas, más rentabilidad por empleado.
    </div>
    <!-- Feature list  <ul class="flex flex-col gap-4 list-none m-0 p-0">
      {
        features.map((f) => (
          <li class="flex items-start gap-4">
            <span
              class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center text-[0.65rem] font-bold text-white"
              style="background: var(--gradient-btn)"
            >
              {f.badge}
            </span>
            <p
              class="text-[0.9rem] text-[#444] leading-relaxed m-0"
              set:html={f.text}
            />
          </li>
        ))
      }
    </ul> -->

    <!-- CTA -->
    <div>
      <a
        href="#"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-white text-sm font-black hover:opacity-90 transition-opacity no-underline"
        style="background: var(--gradient-btn)"
      >
        Automatizar mis procesos →
      </a>
    </div>
  </div>

  <!-- Right: flow grid -->
  <div class="auto-img"><div
    class="-mx-3.5 h-full cursor-default select-none overflow-clip [mask-image:radial-gradient(180%_95%_at_-10%_0%,black_80%,transparent_100%)]"
  >
    <img
      src="/frame-3.svg"
      data-image-component="true"
      alt="Panel de contabilidad"
      loading="lazy"
      decoding="async"
      width="600"
      height="600"
      class="mx-3.5 origin-top rounded-xl border border-neutral-200 bg-white shadow-[0_20px_20px_0_#00000017] md:origin-top-left"
    />
  </div></div>
</section>

<style>
  .auto-section {
    overflow: clip;
  }

  .auto-text {
    opacity: 0;
    transition: opacity 2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .auto-img {
    opacity: 0;
    transform: translateX(160px);
    transition:
      opacity 2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (max-width: 768px) {
    .auto-img { transform: translateX(60px); }
  }

  .auto-text.in-view { opacity: 1; }
  .auto-img.in-view  { opacity: 1; transform: translateX(0); }
</style>

<script>
  const section = document.querySelector(".auto-section") as HTMLElement;
  const text    = document.querySelector(".auto-text") as HTMLElement;
  const img     = document.querySelector(".auto-img") as HTMLElement;

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        text.classList.add("in-view");
        img.classList.add("in-view");
      } else {
        text.classList.remove("in-view");
        img.classList.remove("in-view");
      }
    },
    { threshold: window.innerWidth < 768 ? 0.15 : 0.75 }
  );

  observer.observe(section);
</script>
