---
import Image from "astro/components/Image.astro";

const rows = [
  { label: "Ventas gravadas", value: "S/ 248,310.00", highlight: false },
  { label: "IGV ventas", value: "S/ 44,695.80", highlight: false },
  { label: "Compras gravadas", value: "S/ 142,880.00", highlight: false },
  { label: "Crédito fiscal", value: "- S/ 25,718.40", highlight: false },
  { label: "Percepciones aplicadas", value: "- S/ 737.40", highlight: false },
];
---

<section
  class="contabilidad-section max-w-[1280px] mx-auto px-8 py-16 grid md:grid-cols-2 items-center gap-20"
>
  <!-- Left -->
  <div class="contabilidad-text flex flex-col gap-6">
    <!-- Eyebrow -->
    <div class="flex items-center gap-3">
      <span class="w-8 h-[2px] bg-pink"></span>
      <span class="text-[0.75rem] font-bold tracking-[0.15em] text-pink uppercase">Contabilidad</span>
    </div>

    <!-- Headline -->
    <h2 class="font-obli text-[clamp(2.2rem,4vw,3.2rem)] font-bold leading-[1.05] text-[var(--black)] m-0">
      Si estás ocupado,<br />
    <span class="italic bg-clip-text text-transparent bg-gradient-to-r from-pink to-orange" style="-webkit-box-decoration-break:clone;box-decoration-break:clone;padding:0 0.1em;">
        ¿quién dirige<br />tu empresa?
    </span>
    </h2>

    <!-- Body -->
    <p class="text-[0.95rem] text-[#444] leading-relaxed max-w-[500px] m-0">
      Nos encargamos de tu contabilidad, pero eso es solo el comienzo. Contabilidad a prueba de auditorías.
      <strong class="text-[var(--black)]">"Sabemos que el sistema tributario peruano parece un laberinto. Nosotros somos tu mapa y tu brújula."</strong>
      No somos los contadores que solo aparecen para pedirte facturas a fin de mes. Somos tus aliados financieros. Gestionamos tus impuestos con precisión quirúrgica para garantizar cumplimiento total ante la SUNAT y, lo más importante, optimizamos tu carga fiscal legalmente para que tu flujo de caja respire. Paga lo justo".
    </p>

    <!-- CTA -->
    <div>
      <a
        href="https://wa.link/m7nowd"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-white text-sm font-black hover:opacity-90 transition-opacity no-underline"
        style="background: var(--gradient-btn)"
      >
        ORDENAR MI EMPRESA →
      </a>
    </div>
  </div>

  <!-- Right: PDT card -->
  <div class="contabilidad-img -mx-3.5 h-full cursor-default select-none overflow-clip [mask-image:radial-gradient(180%_95%_at_-10%_0%,black_80%,transparent_100%)]">
    <Image src={"/frame-2.svg"} alt={"Panel de contabilidad"} width={600} height={600} class={"mx-3.5 origin-top scale-95 rounded-xl border border-neutral-200 bg-white shadow-[0_20px_20px_0_#00000017] md:origin-top-left"} />
  </div>
</section>

<style>
  .contabilidad-section {
    overflow: clip;
  }

  /* Estado inicial */
  .contabilidad-text {
    opacity: 0; 
    transition: opacity 2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .contabilidad-img {
    opacity: 0;
    transform: translateX(160px);
    transition:
      opacity 2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (max-width: 768px) {
    .contabilidad-img { transform: translateX(60px); }
  }

  /* Estado visible */
  .contabilidad-text.in-view {
    opacity: 1;
  }

  .contabilidad-img.in-view {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  const section = document.querySelector(".contabilidad-section") as HTMLElement;
  const text    = document.querySelector(".contabilidad-text") as HTMLElement;
  const img     = document.querySelector(".contabilidad-img") as HTMLElement;

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        text.classList.add("in-view");
        img.classList.add("in-view");
      } else {
        text.classList.remove("in-view");
        img.classList.remove("in-view");
      }
    },
    { threshold: window.innerWidth < 768 ? 0.15 : 0.75 }
  );

  observer.observe(section);
</script>
