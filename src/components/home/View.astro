---
import Image from "astro/components/Image.astro";
import Hero from "../ui/Hero.astro";
---

<div style="background: var(--gradient-bg); color: var(--white)">
  <Hero/>

  <!-- HERO SECTION -->
  <section
    class="max-w-[1280px] mx-auto px-8 py-24 grid md:grid-cols-2 items-center gap-16"
  >
    <!-- Left -->
    <div class="flex flex-col gap-6">
      <!-- Badge -->

      <!-- Headline -->
      <h1
        data-animate="fade-in"
        class="font-obli text-5xl md:text-6xl leading-none tracking-[-0.025em] font-bold text-white mt-[18px] mb-[22px] text-balance"
      >
        Tu socio diseñado para
        <span class="relative inline-block">
          <span
            id="rotating-word"
            class="italic font-semibold bg-clip-text text-transparent bg-gradient-to-r from-pink to-orange"
            >crecer tu negocio.</span
          >
          <svg
            viewBox="0 0 200 14"
            preserveAspectRatio="none"
            class="absolute left-0 right-0 bottom-[-6px] w-full h-[12px]"
          >
            <path
              d="M2,8 C50,2 120,12 198,6"
              stroke="url(#heroUnder)"
              stroke-width="3"
              fill="none"
              stroke-linecap="round"></path>
            <defs>
              <linearGradient id="heroUnder" x1="0" x2="1">
                <stop offset="0" stop-color="#F0007F"></stop>
                <stop offset="1" stop-color="#F77C1E"></stop>
              </linearGradient>
            </defs>
          </svg>
        </span>
      </h1>

      <!-- Description -->
      <p
        data-animate="fade-in" data-animate-delay="120"
        class="text-[0.975rem] text-white/80 leading-relaxed max-w-[460px] m-0"
      >
        Integramos la Contabilidad, el blindaje Legal y la Automatización como
        un solo servicio. Simplificamos la complejidad regulatoria, repensamos
        las barreras legales y automatizamos tus equipos contables para que tú
        lideres tu industria y tengas ventajas competitivas reales.
      </p>

      <!-- CTAs -->
      <div data-animate="fade-in" data-animate-delay="220" class="flex items-center gap-4 flex-wrap">
        <a
          href="#"
          class="px-6 py-3 text-[0.95rem] font-black uppercase rounded-full text-white no-underline hover:opacity-90 transition-opacity"
          style="background: var(--gradient-btn)"
        >
          Agenda una reunión →
        </a>
      </div>
    </div>

    <!-- Right: Mock UI -->
    <div class="relative hero-images">
      <Image
        alt={"Dashboard"}
        width={1920}
        height={1080}
        src={"/dashboard.svg"}
        class={"shadow-xl hero-img-main"}
      />
      <Image
        alt={"Dashboard"}
        width={702}
        height={408}
        src={"/BG.svg"}
        class={"w-1/2 rounded-xl absolute bottom-20 md:bottom-34 -right-5 md:-right-10 shadow-xl hero-img-secondary"}
      />
    </div>
  </section>

  <!-- LOGOS STRIP -->
  <div class="pt-8 pb-12 text-center overflow-hidden">
    <p class="text-[0.8rem] text-black/45 mb-6">
      + 180 empresas peruanas confían su back-office a EMMERGIA
    </p>
    <div class="relative">
      <!-- fade edges -->
      <div
        class="absolute inset-y-0 left-0 w-24 z-10 pointer-events-none"
        style="background: linear-gradient(to right, white, transparent)"
      >
      </div>
      <div
        class="absolute inset-y-0 right-0 w-24 z-10 pointer-events-none"
        style="background: linear-gradient(to left, white, transparent)"
      >
      </div>
      <!-- track -->
      <div id="marquee-track" class="flex items-center gap-14 w-max"></div>
    </div>
  </div>
</div><!-- end gradient wrapper -->

<style>
  /* Hero images — scale desde top-right */
  .hero-img-main {
    opacity: 0;
    transform: scale(0.88);
    transform-origin: top right;
    transition: opacity 2s cubic-bezier(0.22, 1, 0.36, 1),
                transform 2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-img-secondary {
    opacity: 0;
    transform: scale(0.88);
    transform-origin: top right;
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.18s,
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.18s;
  }
  .hero-images.is-visible .hero-img-main,
  .hero-images.is-visible .hero-img-secondary {
    opacity: 1;
    transform: scale(1);
  }

  #rotating-word {
    display: inline-block;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }
  #rotating-word.exit {
    opacity: 0;
    transform: translateY(-8px);
  }
  #rotating-word.enter {
    opacity: 0;
    transform: translateY(8px);
  }
</style>

<script>
  // ── Hero images entrance ──
  const heroImages = document.querySelector(".hero-images") as HTMLElement;
  if (heroImages) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          heroImages.classList.add("is-visible");
          obs.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    obs.observe(heroImages);
  }

  // ── Rotating word ──
  const words = [
    "crecer tu patrimonio.",
    "aumentar tus ventas",
    "recudir tus procesos",
  ];
  let index = 0;
  const el = document.getElementById("rotating-word") as HTMLElement;

  setInterval(() => {
    el.classList.add("exit");
    setTimeout(() => {
      index = (index + 1) % words.length;
      el.textContent = words[index];
      el.classList.remove("exit");
      el.classList.add("enter");
      requestAnimationFrame(() =>
        requestAnimationFrame(() => el.classList.remove("enter")),
      );
    }, 300);
  }, 2500);

  // ── Marquee infinito ──
  const logos = [
    "CONSORCIO LIMA",
    "ALFA SAC",
    "ANDINA TECH",
    "GRUPO MARÍA",
    "NORTE IMPORT",
    "VERDE RETAIL",
  ];

  const track = document.getElementById("marquee-track") as HTMLElement;

  // Duplicamos para loop continuo
  [...logos, ...logos].forEach((name) => {
    const span = document.createElement("span");
    span.textContent = name;
    span.className =
      "text-[0.8rem] font-bold tracking-[0.1em] text-black/35 whitespace-nowrap";
    track.appendChild(span);
  });

  let x = 0;
  let paused = false;
  const speed = 0.5; // px por frame

  track.addEventListener("mouseenter", () => (paused = true));
  track.addEventListener("mouseleave", () => (paused = false));

  function animate() {
    if (!paused) {
      x -= speed;
      // resetea cuando recorre exactamente la mitad (el set original)
      const half = track.scrollWidth / 2;
      if (Math.abs(x) >= half) x = 0;
      track.style.transform = `translateX(${x}px)`;
    }
    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);
</script>
