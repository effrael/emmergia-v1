---
import Hero from "../ui/Hero.astro";
---

<div style="background: var(--gradient-bg); color: var(--white)">
  <Hero />

  <!-- HERO SECTION -->
  <section
    class="max-w-[1280px] mx-auto px-8 pt-24 pb-16 grid grid-cols-2 items-center gap-16"
  >
    <!-- Left -->
    <div class="flex flex-col gap-6">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 bg-white/[0.07] border border-white/[0.12] rounded-full px-4 py-1.5 text-[0.78rem] text-white/80 w-fit"
      >
        <span class="w-[7px] h-[7px] rounded-full bg-pink shrink-0"></span>
        <span
          class="bg-clip-text font-obli text-transparent font-bold italic text-white"
        >
          EL TIEMPO ES DINERO - AHORRA AMBOS
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="font-obli text-6xl leading-none tracking-[-0.025em] font-bold text-white mt-[18px] mb-[22px] text-balance"
      >
        Contabilidad que
        <span class="relative inline-block">
          <span
            id="rotating-word"
            class="italic font-semibold bg-clip-text text-transparent bg-gradient-to-r from-pink to-orange"
            >protege.</span
          >
          <svg
            viewBox="0 0 200 14"
            preserveAspectRatio="none"
            class="absolute left-0 right-0 bottom-[-6px] w-full h-[12px]"
          >
            <path
              d="M2,8 C50,2 120,12 198,6"
              stroke="url(#heroUnder)"
              stroke-width="3"
              fill="none"
              stroke-linecap="round"></path>
            <defs>
              <linearGradient id="heroUnder" x1="0" x2="1">
                <stop offset="0" stop-color="#F0007F"></stop>
                <stop offset="1" stop-color="#F77C1E"></stop>
              </linearGradient>
            </defs>
          </svg>
        </span>
      </h1>

      <!-- Description -->
      <p
        class="text-[0.975rem] text-white/80 leading-relaxed max-w-[460px] m-0"
      >
        Integramos la Contabilidad, el blindaje Legal y la Automatización como
        un solo servicio. Deja de apagar incendios administrativos y recupera el
        tiempo para hacer lo que mejor sabes hacer: crecer.
      </p>

      <!-- CTAs -->
      <div class="flex items-center gap-4 flex-wrap">
        <a
          href="#"
          class="px-6 py-3 text-[0.95rem] font-semibold rounded-full text-white no-underline hover:opacity-90 transition-opacity"
          style="background: var(--gradient-btn)"
        >
          Agenda una reunión →
        </a>
        <a
          href="#"
          class="px-6 py-3 text-[0.95rem] font-semibold rounded-full text-white border border-white/25 bg-white/5 hover:bg-white/10 transition-colors no-underline"
        >
          Ver servicios
        </a>
      </div>
    </div>

    <!-- Right: Mock UI -->
    <div class="relative h-[380px]">
      <!-- Dashboard card -->
      <div
        class="absolute left-0 top-0 w-[76%] bg-white/[0.96] rounded-[14px] shadow-[0_32px_80px_rgba(0,0,0,0.5)] overflow-hidden text-[#111]"
      >
        <!-- Chrome bar -->
        <div class="bg-[#f0f0f0] px-3 py-2 flex items-center gap-3">
          <div class="flex gap-[5px]">
            <span class="w-[10px] h-[10px] rounded-full bg-[#ddd]"></span>
            <span class="w-[10px] h-[10px] rounded-full bg-[#ddd]"></span>
            <span class="w-[10px] h-[10px] rounded-full bg-[#ddd]"></span>
          </div>
          <div
            class="text-[0.7rem] text-[#888] bg-white rounded-md px-2 py-0.5"
          >
            app.emmergia.pe / tablero
          </div>
        </div>
        <!-- Body -->
        <div class="p-4">
          <div class="flex justify-between items-start mb-3">
            <div>
              <div class="text-base font-bold text-[#111]">
                Tablero financiero
              </div>
              <div class="text-[0.7rem] text-[#888] mt-0.5">
                Abril 2026 · actualizado hace 2 min
              </div>
            </div>
            <div class="flex gap-1.5">
              <button
                class="text-[0.7rem] px-2 py-0.5 rounded-md bg-[#111] text-white border-none cursor-pointer"
                >Resumen</button
              >
              <button
                class="text-[0.7rem] px-2 py-0.5 rounded-md bg-[#eee] text-[#555] border-none cursor-pointer"
                >SUN...</button
              >
            </div>
          </div>
          <!-- Stats -->
          <div class="flex gap-2 mb-3">
            <div class="flex-1 bg-[#f7f7f9] rounded-lg p-2.5">
              <div
                class="text-[0.6rem] text-[#999] font-semibold tracking-wide"
              >
                INGRESOS MES
              </div>
              <div class="text-base font-bold text-[#111] mt-0.5">
                S/ 248,310
              </div>
              <div class="text-[0.65rem] text-green-600 font-medium mt-0.5">
                ▲ 12.4% vs marzo
              </div>
            </div>
            <div class="flex-1 bg-[#f7f7f9] rounded-lg p-2.5">
              <div
                class="text-[0.6rem] text-[#999] font-semibold tracking-wide"
              >
                IGV POR PAGAR
              </div>
              <div class="text-base font-bold text-[#111] mt-0.5">
                S/ 18,240
              </div>
              <div class="text-[0.65rem] text-amber-600 font-medium mt-0.5">
                Vence 18/05
              </div>
            </div>
            <div class="flex-[0.6] bg-[#f7f7f9] rounded-lg p-2.5">
              <div
                class="text-[0.6rem] text-[#999] font-semibold tracking-wide leading-snug"
              >
                AHORRO<br />FISCAL<br />YTD
              </div>
            </div>
          </div>
          <!-- Chart -->
          <div class="text-[0.68rem] text-[#aaa] mb-1">
            Utilidad vs proyección
          </div>
          <svg
            viewBox="0 0 300 80"
            preserveAspectRatio="none"
            width="100%"
            height="80"
          >
            <defs>
              <linearGradient id="chart-grad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="var(--pink)"></stop>
                <stop offset="100%" stop-color="var(--orange)"></stop>
              </linearGradient>
            </defs>
            <polyline
              points="0,70 50,60 100,50 150,40 200,25 250,15 300,8"
              fill="none"
              stroke="url(#chart-grad)"
              stroke-width="2.5"
              stroke-linecap="round"></polyline>
            <polyline
              points="0,70 50,65 100,60 150,55 200,48 250,42 300,35"
              fill="none"
              stroke="#F77C1E"
              stroke-width="2"
              stroke-dasharray="6,4"
              stroke-linecap="round"
              opacity="0.5"></polyline>
          </svg>
        </div>
      </div>

      <!-- Mobile card -->
      <div
        class="absolute right-0 bottom-0 w-[44%] rounded-[18px] overflow-hidden text-white shadow-[0_24px_60px_rgba(240,0,127,0.4)]"
        style="background: linear-gradient(160deg, var(--pink), var(--orange))"
      >
        <div class="px-4 pt-4 pb-3">
          <div class="text-[0.7rem] opacity-80 mb-0.5">Flujo de caja hoy</div>
          <div class="text-[1.5rem] font-extrabold tracking-tight">
            S/ 38,420
          </div>
          <div class="text-[0.62rem] opacity-75 mt-0.5">
            3 conciliaciones automáticas
          </div>
        </div>
        <div
          class="mx-2.5 mb-2.5 bg-white rounded-[10px] px-3 py-2 flex flex-col gap-1.5"
        >
          <div class="flex justify-between items-center">
            <span class="text-[0.65rem] text-[#666]">Hoy 16:02</span>
            <span class="text-[0.7rem] font-bold text-green-600">+4,820</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-[0.65rem] text-[#666]">Hoy 11:45</span>
            <span class="text-[0.7rem] font-bold text-red-600">-880</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-[0.65rem] text-[#666]">Cliente: ALFA SAC</span>
            <span class="text-[0.7rem] font-bold text-green-600">+12,640</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-[0.65rem] text-[#666]">Programado 30/04</span>
            <span class="text-[0.7rem] font-bold text-red-600">-18,200</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LOGOS STRIP -->
  <div class="pt-8 pb-12 text-center overflow-hidden">
    <p class="text-[0.8rem] text-black/45 mb-6">
      + 180 empresas peruanas confían su back-office a EMMERGIA
    </p>
    <div class="relative">
      <!-- fade edges -->
      <div
        class="absolute inset-y-0 left-0 w-24 z-10 pointer-events-none"
        style="background: linear-gradient(to right, white, transparent)"
      >
      </div>
      <div
        class="absolute inset-y-0 right-0 w-24 z-10 pointer-events-none"
        style="background: linear-gradient(to left, white, transparent)"
      >
      </div>
      <!-- track -->
      <div id="marquee-track" class="flex items-center gap-14 w-max"></div>
    </div>
  </div>
</div><!-- end gradient wrapper -->

<style>
  #rotating-word {
    display: inline-block;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }
  #rotating-word.exit {
    opacity: 0;
    transform: translateY(-8px);
  }
  #rotating-word.enter {
    opacity: 0;
    transform: translateY(8px);
  }
</style>

<script>
  // ── Rotating word ──
  const words = ["protege.", "aumenta.", "mejora."];
  let index = 0;
  const el = document.getElementById("rotating-word") as HTMLElement;

  setInterval(() => {
    el.classList.add("exit");
    setTimeout(() => {
      index = (index + 1) % words.length;
      el.textContent = words[index];
      el.classList.remove("exit");
      el.classList.add("enter");
      requestAnimationFrame(() =>
        requestAnimationFrame(() => el.classList.remove("enter")),
      );
    }, 300);
  }, 2500);

  // ── Marquee infinito ──
  const logos = [
    "CONSORCIO LIMA",
    "ALFA SAC",
    "ANDINA TECH",
    "GRUPO MARÍA",
    "NORTE IMPORT",
    "VERDE RETAIL",
  ];

  const track = document.getElementById("marquee-track") as HTMLElement;

  // Duplicamos para loop continuo
  [...logos, ...logos].forEach((name) => {
    const span = document.createElement("span");
    span.textContent = name;
    span.className =
      "text-[0.8rem] font-bold tracking-[0.1em] text-black/35 whitespace-nowrap";
    track.appendChild(span);
  });

  let x = 0;
  let paused = false;
  const speed = 0.5; // px por frame

  track.addEventListener("mouseenter", () => (paused = true));
  track.addEventListener("mouseleave", () => (paused = false));

  function animate() {
    if (!paused) {
      x -= speed;
      // resetea cuando recorre exactamente la mitad (el set original)
      const half = track.scrollWidth / 2;
      if (Math.abs(x) >= half) x = 0;
      track.style.transform = `translateX(${x}px)`;
    }
    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);
</script>
