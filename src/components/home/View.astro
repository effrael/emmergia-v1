---
import Image from "astro/components/Image.astro";
import Hero from "../ui/Hero.astro";
import Animation from "../ui/Animation.astro";
---

<div style="background: var(--gradient-bg); color: var(--white)">
  <Hero/>

  <!-- HERO SECTION -->
  <section
    class="max-w-[1280px] mx-auto px-8 py-28 d:py-40 grid md:grid-cols-2 items-center gap-16"
  >
    <!-- Left -->
    <div class="flex flex-col gap-6">
      <!-- Badge -->

      <!-- Headline -->
      <h1
        data-animate="fade-in"
        class=" text-6xl leading-none tracking-[-0.025em] font-black text-white mt-[18px] mb-[22px] text-balance"
      >
        Tu socio diseñado para </br>
        <span class="relative ">
          <span
            id="rotating-word"
            class="font-black h-10 text-5xl"

            ></span
          >
        </span>
      </h1>

      <!-- Description -->
      <p
        data-animate="fade-in" data-animate-delay="120"
        class="text-[0.975rem] text-white/90 leading-relaxed max-w-[460px] m-0"
      >
        Integramos la Contabilidad, el blindaje Legal y la Automatización como
        un solo servicio. Simplificamos la complejidad regulatoria, repensamos
        las barreras legales y automatizamos tus equipos contables para que tú
        lideres tu industria y tengas ventajas competitivas reales.
      </p>

      <!-- CTAs -->
      <div data-animate="fade-in" data-animate-delay="220" class="flex items-center gap-4 flex-wrap">
        <a
          href="https://wa.link/m7nowd"
          target="_blank"
          class="px-6 py-3 text-[0.95rem] font-black uppercase rounded-full text-white no-underline hover:opacity-90 transition-opacity"
          style="background: var(--gradient-btn)"
        >
          Agenda una reunión →
        </a>
      </div>
    </div>

    <!-- Right: Mock UI -->
    <div class="relative hero-images">
      <Animation />
    </div>
  </section>

  <!-- LOGOS STRIP -->
  <div class="pt-8 pb-12 text-center overflow-hidden">
    <p class="text-[0.8rem] text-black/45 mb-6">
      + 180 empresas peruanas confían su back-office a EMMERGIA
    </p>
    <div class="relative">
      <!-- fade edges -->
      <div
        class="absolute inset-y-0 left-0 w-24 z-10 pointer-events-none"
        style="background: linear-gradient(to right, white, transparent)"
      >
      </div>
      <div
        class="absolute inset-y-0 right-0 w-24 z-10 pointer-events-none"
        style="background: linear-gradient(to left, white, transparent)"
      >
      </div>
      <!-- track -->
      <div id="marquee-track" class="flex items-center gap-14 w-max"></div>
    </div>
  </div>
</div><!-- end gradient wrapper -->

<style is:global>
  /* Hero images — scale desde top-right */
  .hero-img-main {
    opacity: 0;
    transform: scale(0.88);
    transform-origin: top right;
    transition: opacity 2s cubic-bezier(0.22, 1, 0.36, 1),
                transform 2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-img-secondary {
    opacity: 0;
    transform-origin: top right;
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.18s;
    animation: float-secondary 3s ease-in-out infinite;
  }
  .hero-images.is-visible .hero-img-main {
    opacity: 1;
    transform: scale(1);
    animation: float-main 6s ease-in-out infinite;
  }
  .hero-images.is-visible .hero-img-secondary {
    opacity: 1;
  }

  @keyframes float-main {
    0%,  100% { transform: scale(1) translateY(0px);   }
    50%        { transform: scale(1) translateY(-10px); }
  }
  @keyframes float-secondary {
    0%,  100% { transform: translateY(0px);   }
    50%        { transform: translateY(-12px); }
  }

  @keyframes letter-enter {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0);     }
  }
  @keyframes letter-exit {
    from { opacity: 1; transform: translateY(0);    }
    to   { opacity: 0; transform: translateY(10px); }
  }

  #rotating-word {
    display: inline-block;
  }
</style>

<script>
  // ── Hero images entrance ──
  const heroImages = document.querySelector(".hero-images") as HTMLElement;
  if (heroImages) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          heroImages.classList.add("is-visible");
          obs.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    obs.observe(heroImages);
  }

  // ── Rotating word ──
  const words = [
    "crecer tu negocio.",
    "crecer tu patrimonio.",
    "aumentar tus ventas.",
    "reducir tus procesos.",
  ];
  let index = 0;
  const el = document.getElementById("rotating-word") as HTMLElement;

  const BASE  = 0.12;   // s — delay inicial (igual que referencia)
  const STEP  = 0.015;  // s — stagger entre letras
  const DUR   = 0.75;   // s — duración de cada letra

  function enterWord(text: string) {
    el.innerHTML = "";
    [...text].forEach((char, i) => {
      const span = document.createElement("span");
      span.textContent = char === " " ? "\u00A0" : char;
      span.style.cssText = `
        display: inline-block;
        background: linear-gradient(to right, #f0007f, #f77c1e);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: letter-enter ${DUR}s cubic-bezier(0.22,1,0.36,1) ${BASE + i * STEP}s both;
      `;
      el.appendChild(span);
    });
  }

  function exitWord(): Promise<void> {
    return new Promise((resolve) => {
      const spans = el.querySelectorAll<HTMLElement>("span");
      spans.forEach((s, i) => {
        s.style.animation = `letter-exit ${DUR}s cubic-bezier(0.22,1,0.36,1) ${BASE + i * STEP}s both`;
      });
      const wait = (BASE + (spans.length - 1) * STEP + DUR) * 1000;
      setTimeout(resolve, wait);
    });
  }

  // Texto inicial
  enterWord(words[0]);

  async function cycle() {
    await new Promise((r) => setTimeout(r, 3200));
    while (true) {
      await exitWord();
      index = (index + 1) % words.length;
      enterWord(words[index]);
      await new Promise((r) => setTimeout(r, 3200));
    }
  }
  cycle();

  // ── Marquee infinito ──
  const logos = [
    "CONSORCIO LIMA",
    "ALFA SAC",
    "ANDINA TECH",
    "GRUPO MARÍA",
    "NORTE IMPORT",
    "VERDE RETAIL",
  ];

  const track = document.getElementById("marquee-track") as HTMLElement;

  // Duplicamos para loop continuo
  [...logos, ...logos].forEach((name) => {
    const span = document.createElement("span");
    span.textContent = name;
    span.className =
      "text-[0.8rem] font-bold tracking-[0.1em] text-black/35 whitespace-nowrap";
    track.appendChild(span);
  });

  let x = 0;
  let paused = false;
  const speed = 0.5; // px por frame

  track.addEventListener("mouseenter", () => (paused = true));
  track.addEventListener("mouseleave", () => (paused = false));

  function animate() {
    if (!paused) {
      x -= speed;
      // resetea cuando recorre exactamente la mitad (el set original)
      const half = track.scrollWidth / 2;
      if (Math.abs(x) >= half) x = 0;
      track.style.transform = `translateX(${x}px)`;
    }
    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);
</script>
