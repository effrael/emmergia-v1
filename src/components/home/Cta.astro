<section class="cta-section max-w-[1280px] mx-auto px-8 py-16" style="perspective: 1200px;">
  <div
    class="cta-card relative rounded-2xl overflow-hidden px-8 py-20 flex flex-col items-center text-center gap-6"
    style="background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(240,0,127,0.35), transparent 70%), radial-gradient(ellipse 50% 60% at 80% 100%, rgba(180,40,0,0.5), transparent 65%), #100a0f; transform-style: preserve-3d; will-change: transform, opacity;"
  >

    <!-- Headline -->
    <h2 class="font-obli text-[clamp(2rem,4vw,3rem)] font-bold leading-tight text-white m-0">
      Empieza hoy.
      <em class="not-italic bg-clip-text text-transparent bg-gradient-to-r from-pink to-orange">
        Crece mañana.
      </em>
    </h2>

    <!-- Subtext -->
    <p class="text-[0.9rem] text-white/55 leading-relaxed max-w-[420px] m-0">
      Agenda una reunión de diagnóstico de 30 min. Sin costo. Sin letra chica.
      Te diremos exactamente dónde estás dejando dinero en la mesa.
    </p>

    <!-- CTA -->
    <a
      href="https://wa.link/m7nowd"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-white text-sm font-semibold hover:opacity-90 transition-opacity no-underline"
      style="background: var(--gradient-btn)"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Prueba Gratis
    </a>

  </div>
</section>

<script>
  const section = document.querySelector(".cta-section") as HTMLElement;
  const card    = document.querySelector(".cta-card") as HTMLElement;

  function update() {
    const rect     = section.getBoundingClientRect();
    const vh       = window.innerHeight;
    // progress: 0 = sección entrando por abajo, 1 = sección saliendo por arriba
    const progress = 1 - (rect.bottom / (vh + rect.height));
    const clamped  = Math.max(0, Math.min(1, progress));

    // Mapea 0→0.5 (entrada): rotateX de 28° → 0°
    // Mapea 0.5→1  (salida):  rotateX de 0° → -28°
    const rotateX = clamped < 0.5
      ? 28 - clamped * 2 * 28          // entrada: 28 → 0
      : (clamped - 0.5) * 2 * -28;    // salida:   0 → -28

    const opacity = clamped < 0.15
      ? clamped / 0.15                  // fade in al entrar
      : clamped > 0.85
        ? 1 - (clamped - 0.85) / 0.15  // fade out al salir
        : 1;

    card.style.transform = `rotateX(${rotateX}deg)`;
    card.style.opacity   = String(opacity);
  }

  window.addEventListener("scroll", update, { passive: true });
  update();
</script>
